    </path>

    <!-- Squishy, Organic Jelly Play Button (rounded, bulging triangle) -->
    <path
        android:pathData="M 44.5 35.5 C 43.2 34.2 41 35.1 41 37 L 41 71 C 41 72.9 43.2 73.8 44.5 72.5 L 69.5 55.5 C 70.8 54.6 70.8 53.4 69.5 52.5 Z">
