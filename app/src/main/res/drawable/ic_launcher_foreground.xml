    <!-- Jelly shine dot -->
    <path
        android:pathData="M 45 42 A 2 2 0 1 1 41 42 A 2 2 0 1 1 45 42 Z"
        android:fillColor="#FFFFFF"
        android:fillAlpha="0.6"/>
